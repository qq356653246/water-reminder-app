<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️ 设置"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <!-- 每日目标杯数 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="每日目标（杯）"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        android:background="@drawable/number_picker_background"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecreaseGoal"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="−"
            android:textSize="24sp"
            app:cornerRadius="28dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <TextView
            android:id="@+id/txtGoalCups"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="8"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/blue_water"
            android:gravity="center"
            android:fontFamily="sans-serif-light" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIncreaseGoal"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="+"
            android:textSize="24sp"
            app:cornerRadius="28dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <!-- 杯子容量 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/cup_size_ml"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        android:background="@drawable/number_picker_background"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecreaseCupSize"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="−"
            android:textSize="24sp"
            app:cornerRadius="28dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <TextView
            android:id="@+id/txtCupSize"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="250"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/blue_water"
            android:gravity="center"
            android:fontFamily="sans-serif-light" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIncreaseCupSize"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="+"
            android:textSize="24sp"
            app:cornerRadius="28dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/common_sizes"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="8dp" />

    <!-- 提醒间隔 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="提醒间隔"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="20dp" />

    <Spinner
        android:id="@+id/spinnerInterval"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/spinner_background"
        android:padding="12dp"
        android:textSize="16sp" />

    <!-- 喝水时间段 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="喝水时间段（在此时间段内提醒）"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="从"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartTime"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="08:00"
            android:textSize="16sp"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="到"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndTime"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="22:00"
            android:textSize="16sp"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <!-- 保存按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveSettings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="8dp"
        android:text="💾 保存设置"
        android:textSize="17sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/blue_water" />

</LinearLayout>
